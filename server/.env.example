# คัดลอกเป็น .env แล้วใส่ค่าจริง (อย่า commit .env)
# PORT = พอร์ตที่ Backend API (Express) จะรัน (ใช้ 3002 เพื่อไม่ชนกับ Vite ที่ 3000/3001)
PORT=3002

# Supabase: แทนที่ [YOUR-PASSWORD] ด้วยรหัสผ่าน Database
# ถ้ารหัสผ่านมีอักขระพิเศษ (@ # : / ฯลฯ) ต้อง encode: @ → %40, # → %23, : → %3A
# ถ้า 5432 ไม่ได้ (ETIMEDOUT) ให้เปลี่ยนเป็นพอร์ต 6543 (pooler) — โฮสต์เดิม
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.cawktiitkxxnxaefnkto.supabase.co:6543/postgres

# สร้างคีย์ยาวๆ สำหรับ sign JWT (เช่น openssl rand -base64 32)
JWT_SECRET=your-super-secret-key-change-in-production

# จำกัดการลงเวลาเฉพาะเมื่อเชื่อมต่อ WiFi บริษัท (Connex_fibre_2.4G) ที่ออฟฟิศ (ถ้าไม่ตั้ง = ไม่อนุญาตทุกเครือข่าย)
# ระบบตรวจจาก IP — ตั้งเป็นช่วง IP ที่ router WiFi Connex_fibre_2.4G แจก (เช่น 192.168.1. หรือ 10.0.0.)
# รูปแบบ: คั่นด้วย comma — IP เต็ม (1.2.3.4) หรือ prefix (192.168.1.)
# ตัวอย่าง: OFFICE_IP_RANGES=192.168.1.,10.0.0.
# บน Vercel ต้องตั้งใน Backend Environment Variables
# OFFICE_IP_RANGES=
